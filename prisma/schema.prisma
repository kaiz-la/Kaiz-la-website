generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for Prisma Migrate. On Neon use the
  // "-pooler" host for DATABASE_URL and the direct host for DIRECT_URL.
  directUrl = env("DIRECT_URL")
}

model Conversation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  messages  Message[]
  title     String? 
  stage     String    @default("greeting")
  lead      Lead?
}

model Message {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  content        String       @db.Text
  role           String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
}

model Shipment {
  id                String          @id @default(cuid())
  trackingId        String          @unique
  customerName      String?
  productSummary    String?
  origin            String?
  destination       String?
  status            String          @default("SOURCING")
  estimatedDelivery DateTime?
  notes             String?         @db.Text
  events            ShipmentEvent[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId  String
  status      String
  description String?  @db.Text
  location    String?
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([shipmentId])
}

model Lead {
  id               String       @id @default(cuid())
  createdAt        DateTime     @default(now())
  conversation     Conversation @relation(fields: [conversationId], references: [id])
  conversationId   String       @unique
  name             String?
  company          String?
  email            String?
  phone            String?
  productInterest  String?
  orderVolume      String?
  preferredRegion  String?
  sourcingTimeline String?
  preferredContact String?
  scheduledCall    Boolean      @default(false)
  callDate         DateTime?
  notes            String?      @db.Text
}